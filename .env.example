# ─────────────────────────────────────────────────────────
# ReconnOne — Environment Variables
# Copy this file to .env and fill in your keys.
# ─────────────────────────────────────────────────────────

# NREL Developer Network (one key for all NREL endpoints below)
# Sign up: https://developer.nrel.gov/signup/
# Free tier, 1 000 requests/hour. Used for: AFDC stations, Utility Rates v3, PVWatts v8.
VITE_NREL_API_KEY=

# Z.AI — Web Search (unstructured / scrape-adjacent signals)
# Docs: https://docs.z.ai/api-reference/tools/web-search
# Keys: https://z.ai/manage-apikey/apikey-list
# WARNING: VITE_* is exposed in the browser bundle. Use a server proxy in production.
VITE_ZAI_API_KEY=

# ─── No keys required ──
# EPA Envirofacts — https://data.epa.gov/efservice/
# EPA UST Finder — ArcGIS (national UST/LUST)
# HUD REO — ArcGIS FHA single-family REO
# FHWA Alt-Fuel Corridors — ArcGIS FeatureServer
# EPA EJScreen — https://ejscreen.epa.gov/mapper/ejscreenapi1.html
